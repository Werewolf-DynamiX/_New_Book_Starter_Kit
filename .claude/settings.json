{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prose-checklist-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/version-check.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/save-critical-context.sh"
          }
        ]
      }
    ]
  }
}
